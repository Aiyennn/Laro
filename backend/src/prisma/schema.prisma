generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "mysql"
    url = env("DATABASE_URL")
}

model User {
  user_id   Int      @id @default(autoincrement())
  username  String
  email     String   @unique
  password  String
  reviews   Review[]
}

model Game {
  game_id      Int         @id @default(autoincrement())
  title        String
  description  String?
  developer    Developer   @relation(fields: [developer_id], references: [developer_id])
  developer_id Int
  publisher    Publisher   @relation(fields: [publisher_id], references: [publisher_id])
  publisher_id Int
  release_date DateTime?
  reviews      Review[]
  genres       Game_Genre[]
  platforms    Game_Platform[]
  tags         Game_Tag[]
}

model Review {
  review_id  Int      @id @default(autoincrement())
  user       User     @relation(fields: [user_id], references: [user_id])
  user_id    Int
  game       Game     @relation(fields: [game_id], references: [game_id])
  game_id    Int
  review_text String
  rating     Int
  likes_count Int     @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model Genre {
  genre_id Int        @id @default(autoincrement())
  name     String
  description String?
  games    Game_Genre[]
}

model Game_Genre {
  game     Game  @relation(fields: [game_id], references: [game_id])
  game_id  Int
  genre    Genre @relation(fields: [genre_id], references: [genre_id])
  genre_id Int

  @@id([game_id, genre_id])
}

model Platform {
  platform_id Int    @id @default(autoincrement())
  name        String
  manufacturer String?
  release_year Int?
  games       Game_Platform[]
}

model Game_Platform {
  game       Game     @relation(fields: [game_id], references: [game_id])
  game_id    Int
  platform   Platform @relation(fields: [platform_id], references: [platform_id])
  platform_id Int

  @@id([game_id, platform_id])
}

model Developer {
  developer_id Int     @id @default(autoincrement())
  name         String
  country      String?
  founded_year Int?
  website      String?
  description  String?
  games        Game[]
}

model Publisher {
  publisher_id Int     @id @default(autoincrement())
  name         String
  country      String?
  founded_year Int?
  website      String?
  description  String?
  games        Game[]
}

model Tag {
  tag_id      Int      @id @default(autoincrement())
  name        String
  description String?
  games       Game_Tag[]
}

model Game_Tag {
  game     Game @relation(fields: [game_id], references: [game_id])
  game_id  Int
  tag      Tag  @relation(fields: [tag_id], references: [tag_id])
  tag_id   Int

  @@id([game_id, tag_id])
}